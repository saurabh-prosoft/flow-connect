{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES6",
    "moduleResolution": "node12",
    "lib": [
      "ES6",
      "DOM"
    ],
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": false
  },
  "include": [
    "src/**/*.ts",
    "src/lib/tuna.js"
  ]
}
